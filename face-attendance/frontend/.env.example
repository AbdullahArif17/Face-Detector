NEXT_PUBLIC_API_URL=/api/backend
BACKEND_INTERNAL_URL=http://127.0.0.1:8000
NEXT_PUBLIC_ALLOW_SIGNUP=true
NEXT_PUBLIC_CSRF_COOKIE_NAME=face_attendance_csrf
NEXT_PUBLIC_PRIVACY_CONTACT_EMAIL=
NEXT_PUBLIC_KIOSK_BASE_URL=http://localhost:3000
# Browser requests use the same-origin Next.js proxy by default.
# Production should keep NEXT_PUBLIC_API_URL=/api/backend and use an HTTPS
# BACKEND_INTERNAL_URL pointing at the deployed FastAPI service.
# For phone/tablet testing on the same Wi-Fi, use your PC LAN IP instead:
# NEXT_PUBLIC_API_URL=http://192.168.0.116:8002
# NEXT_PUBLIC_KIOSK_BASE_URL=http://192.168.0.116:3000
# For live mobile camera testing, the kiosk URL must be HTTPS:
# NEXT_PUBLIC_KIOSK_BASE_URL=https://192.168.0.116:3000
