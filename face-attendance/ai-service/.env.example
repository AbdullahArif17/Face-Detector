MIN_IMAGE_HEIGHT=180
MIN_FACE_WIDTH=70
MIN_FACE_HEIGHT=70
MIN_FACE_AREA_RATIO=0.03
MIN_BLUR_SCORE=20
MIN_BRIGHTNESS=35
MAX_BRIGHTNESS=225
AI_API_KEY=change-this-local-ai-service-key
