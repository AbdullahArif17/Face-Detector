# Set AI_API_KEY as a HuggingFace Space secret and use the same value in the backend.
APP_ENV=production
AI_API_KEY=
AI_CORS_ORIGINS=

EMBEDDINGS_DIR=embeddings
RECOGNITION_THRESHOLD=0.58
RECOGNITION_MARGIN=0.03
DEEPFACE_MODEL=ArcFace
DETECTOR_BACKEND=opencv
FALLBACK_DETECTOR_BACKENDS=ssd,mtcnn,retinaface
ENABLE_EMBEDDING_AUGMENTATION=true
MIN_IMAGE_WIDTH=120
MIN_IMAGE_HEIGHT=120
MIN_FACE_WIDTH=30
MIN_FACE_HEIGHT=30
MIN_FACE_AREA_RATIO=0.001
MIN_BLUR_SCORE=8
MIN_BRIGHTNESS=35
MAX_BRIGHTNESS=225
MAX_IMAGE_BYTES=2000000
INFERENCE_CONCURRENCY=1
MAX_ENROLLMENT_IMAGES=3
MIN_ENROLLMENT_SAMPLE_SIMILARITY=0.40
# Enable only after validating DeepFace anti-spoofing on the deployment hardware.
ENABLE_ANTI_SPOOFING=false
