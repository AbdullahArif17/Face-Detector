# Neon: copy the DIRECT connection string, not the pooled "-pooler" URL.
# The application converts postgresql:// to the asyncpg SQLAlchemy driver.
DATABASE_URL=postgresql://YOUR_ROLE:YOUR_PASSWORD@YOUR_ENDPOINT.REGION.aws.neon.tech/neondb?sslmode=require
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
