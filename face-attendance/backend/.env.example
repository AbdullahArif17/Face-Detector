DATABASE_URL=postgresql://[user]:[password]@[host].neon.tech/[dbname]?sslmode=require
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
JWT_ISSUER=face-attendance-api
JWT_AUDIENCE=face-attendance-web
ACCESS_TOKEN_EXPIRE_MINUTES=30
AUTH_COOKIE_NAME=face_attendance_session
CSRF_COOKIE_NAME=face_attendance_csrf
AUTH_COOKIE_SECURE=false
ALLOW_PUBLIC_SIGNUP=true
ENABLE_API_DOCS=true
AI_SERVICE_URL=http://localhost:8001
AI_MODEL_NAME=ArcFace
# Optional. If set, backend sends X-API-Key to the AI service.
AI_API_KEY=
BIOMETRIC_ENCRYPTION_KEY=
# Optional dedicated Fernet key. If omitted, credential encryption derives a
# domain-separated key from BIOMETRIC_ENCRYPTION_KEY.
CREDENTIAL_ENCRYPTION_KEY=
APP_TIMEZONE=Asia/Karachi
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.0.116:3000
META_WHATSAPP_TOKEN=your_global_fallback_token
META_PHONE_NUMBER_ID=your_global_fallback_phone_id
META_WEBHOOK_VERIFY_TOKEN=your_meta_webhook_verify_token
META_APP_SECRET=your_meta_app_secret
META_GRAPH_API_VERSION=v25.0
META_TEMPLATE_LANGUAGE=en
META_TEST_TEMPLATE_LANGUAGE=en_US
META_CHECKIN_TEMPLATE_NAME=
META_CHECKOUT_TEMPLATE_NAME=
META_ABSENT_TEMPLATE_NAME=
META_TEST_TEMPLATE_NAME=hello_world
# Safety allowlist for test deployments. When enabled, all other recipients are blocked.
WHATSAPP_TEST_MODE=false
WHATSAPP_TEST_RECIPIENT=
# Production: use exact HTTPS frontend origins, secure cookies, and disable
# public signup/API docs unless they are intentionally required.
APP_ENV=development
